{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "orders.json",
  "description": "OMS order data. Generate synthetic records that conform to this schema.",
  "type": "object",
  "required": ["orders"],
  "properties": {
    "orders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["order_id", "customer_id", "status", "items", "total_amount", "payment_method", "shipping_address"],
        "properties": {
          "order_id": {
            "type": "string",
            "pattern": "^ORD-[0-9]{5}$",
            "description": "Unique order identifier",
            "example": "ORD-78321"
          },
          "customer_id": {
            "type": "string",
            "description": "Reference to customer in CRM",
            "example": "CUST-001"
          },
          "status": {
            "type": "string",
            "enum": ["placed", "processing", "shipped", "delivered", "cancelled"],
            "description": "Current order status"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2025-05-01T10:30:00Z"
          },
          "estimated_delivery": {
            "type": "string",
            "format": "date",
            "example": "2025-05-08"
          },
          "tracking_number": {
            "type": ["string", "null"],
            "description": "Carrier tracking number. Null if not yet shipped.",
            "example": "TRACK-7X9K2M"
          },
          "shipping_address": {
            "type": "object",
            "required": ["line1", "city", "state", "pincode"],
            "properties": {
              "line1":   { "type": "string", "example": "12 MG Road" },
              "line2":   { "type": "string", "example": "Koramangala" },
              "city":    { "type": "string", "example": "Bengaluru" },
              "state":   { "type": "string", "example": "Karnataka" },
              "pincode": { "type": "string", "example": "560034" }
            }
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "description": "Line items in the order. unit_price * quantity must sum to total_amount.",
            "items": {
              "type": "object",
              "required": ["line_id", "product_id", "name", "quantity", "unit_price", "status"],
              "properties": {
                "line_id": {
                  "type": "integer",
                  "description": "1-indexed line item identifier used for partial cancellation",
                  "example": 1
                },
                "product_id": {
                  "type": "string",
                  "example": "PROD-LAPTOP-001"
                },
                "name": {
                  "type": "string",
                  "example": "Dell Inspiron 15 Laptop"
                },
                "quantity": {
                  "type": "integer",
                  "minimum": 1,
                  "example": 1
                },
                "unit_price": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Price per unit in INR",
                  "example": 55000.00
                },
                "status": {
                  "type": "string",
                  "enum": ["active", "cancelled"],
                  "example": "active"
                }
              }
            }
          },
          "total_amount": {
            "type": "number",
            "minimum": 0,
            "description": "Total order value in INR. Must equal sum of (unit_price * quantity) across all active items.",
            "example": 55000.00
          },
          "payment_method": {
            "type": "string",
            "enum": ["HDFC_CREDIT", "ICICI_DEBIT", "SBI_NETBANKING", "UPI", "COD"],
            "example": "HDFC_CREDIT"
          }
        }
      }
    }
  },
  "_sample_record": {
    "order_id":            "ORD-78321",
    "customer_id":         "CUST-001",
    "status":              "shipped",
    "created_at":          "2025-05-01T10:30:00Z",
    "estimated_delivery":  "2025-05-08",
    "tracking_number":     "TRACK-7X9K2M",
    "shipping_address": {
      "line1":   "12 MG Road",
      "line2":   "Koramangala",
      "city":    "Bengaluru",
      "state":   "Karnataka",
      "pincode": "560034"
    },
    "items": [
      {
        "line_id":    1,
        "product_id": "PROD-LAPTOP-001",
        "name":       "Dell Inspiron 15 Laptop",
        "quantity":   1,
        "unit_price": 55000.00,
        "status":     "active"
      },
      {
        "line_id":    2,
        "product_id": "PROD-BAG-021",
        "name":       "Laptop Backpack",
        "quantity":   1,
        "unit_price": 1500.00,
        "status":     "active"
      }
    ],
    "total_amount":   56500.00,
    "payment_method": "HDFC_CREDIT"
  }
}
